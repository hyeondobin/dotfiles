[global]
    follow = mouse
    width = (0,1500)
    height = 950
    origin = top-center
    offset = 10x50
    scale = 0

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0

    icon_corner_radius = 0
    icon_theme = "breeze-dark, Papirus-Dark"
    icon_position = left
    min_icon_size = 48
    max_icon_size = 128
    icon_path = /usr/share/icons/hicolor/16x16/status/:/usr/share/icons/hicolor/16x16/devices/
    transparency = 5
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 0
    separator_color = frame
    separartor_height = 2
    frame_width = 6
    frame_color = "#aaaaaa"
    gap_size = 0
    sort = yes
    line_height = 10
    font = FiraCode Nerd Font Mono 13
    format = "<b><u>%a:%s</u></b>\n%b\n"
    markup = full
    alignment = center
    vertical_alignment = middle

    show_indicators = yes
    indicate_hidden = yes
    stack_indicators = yes

    idle_threshold = 120
    show_age_threshold = 60
    word_wrap = no
    ellipsize = end
    ignore_newline = no
    notification_limit= 10
    hide_duplicate_count = false
    sticky_history = yes
    always_run_script = true

    title = Dunst
    class = Dunst

    corner_radius = 9
    ignore_dbusclose = false
    force_xwayland = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#E5E9F0"
    foreground = "#2E3440"
    frame_color = "#2E3440"
    timeout = 10

[urgency_normal]
    background = "#2E3440"
    foreground = "#BF616A"
    frame_color = "#BF616A"
    highlight = "#BF616A"
    timeout = 10

[urgency_critical]
    background = "#ffffff"
    foreground = "#900000"
    frame_color = "#900000"
    timeout = 0

