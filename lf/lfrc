set shell fish

set ifs "\n"

set scrolloff 10
# map <enter> to shell commands
map <enter> shell

# execute current file (must be executable)
map x $$f
map X !$f

set period 1
# show info
set info size:time

set icons
# show hidden files
set hidden!
set hiddenfiles ".*:*.aux:*.log:*.bbl:*.blg:*.run.xml"

set drawbox

set number
set relativenumber

set promptfmt "\033[34;1m%d\033[0m\033[1m%f\033[0m"


# quick rename using r
cmd rename %sh -c 'mv -i %f% $0'
map r push :rename<space>

# use a and A to create file and directories
cmd createfile %sh -c 'touch $0'
cmd createdir %sh -c 'mkdir $0'
map a push :createfile<space>
map A push :createdir<space>

# z 
cmd z-jump ${{
        # ZLUA_SCRIPT=""
        lf -remote "send {$id} cd \"$($ZLUA_SCRIPT -e $@ | sed 's/\\/\\\\/g;s/"/\\"/g')\""
    }}
map Z push :z-jump<space>-I<space>
map zb push :z-jump<space>-b<space>
map zz push :z-jump<space>

